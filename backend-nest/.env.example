# PostgreSQL — from Neon dashboard (Connection → Connection String)
DATABASE_URL=postgresql://user:password@host.neon.tech/spoton_challenge?sslmode=require

# OR individual fields (Railway / Neon both provide these)
DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=spoton_challenge

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# Set automatically by Railway
PORT=3001
